---
const siteName = "Hodos Browser";
const tagline = "Browse the web. Own your wallet.";
const description = "The browser with a built-in BitcoinSV wallet. Familiar browsing, native BSV.";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <title>{siteName}</title>
  <link rel="icon" type="image/svg+xml" href="/Hodos_Gold_Icon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  
  <style>
    /* ========== CSS Variables ========== */
    :root {
      /* Brand */
      --gold: #a67c00;
      --gold-dark: #a57d2d;
      --gold-light: #dfbd69;
      
      /* Backgrounds */
      --bg-primary: #0a0a0b;
      --bg-elevated: #141416;
      --border: #1f1f23;
      
      /* Text */
      --text-primary: #ffffff;
      --text-secondary: #b0b7c3;
      --text-muted: #6b7280;
      
      /* Semantic */
      --success: #2e7d32;
      --info: #1a6b6a;
      
      /* Spacing */
      --space-xs: 8px;
      --space-sm: 16px;
      --space-md: 24px;
      --space-lg: 48px;
      --space-xl: 64px;
      --space-2xl: 96px;
      
      /* Typography */
      --font-body: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      
      /* Radius */
      --radius-sm: 6px;
      --radius-md: 8px;
      --radius-lg: 12px;
    }
    
    /* ========== Reset ========== */
    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }
    
    /* ========== Base ========== */
    html {
      scroll-behavior: smooth;
    }
    
    body {
      font-family: var(--font-body);
      background: var(--bg-primary);
      color: var(--text-primary);
      line-height: 1.6;
      font-size: 16px;
    }
    
    a {
      color: var(--gold);
      text-decoration: none;
      transition: color 0.2s;
    }
    
    a:hover {
      color: var(--gold-light);
    }
    
    img {
      max-width: 100%;
      height: auto;
    }
    
    /* ========== Layout ========== */
    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 var(--space-md);
    }
    
    section {
      padding: var(--space-2xl) 0;
    }
    
    /* ========== Header ========== */
    header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      background: rgba(10, 10, 11, 0.9);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }
    
    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 64px;
    }
    
    .logo {
      display: flex;
      align-items: center;
    }

    .logo img {
      height: 32px;
      width: auto;
    }
    
    nav {
      display: flex;
      align-items: center;
      gap: var(--space-md);
    }
    
    nav a {
      color: var(--text-secondary);
      font-size: 14px;
      font-weight: 500;
    }
    
    nav a:hover {
      color: var(--text-primary);
    }
    
    /* ========== Buttons ========== */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: var(--space-xs);
      padding: 12px 24px;
      border-radius: var(--radius-md);
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      border: none;
      text-decoration: none;
    }
    
    .btn-primary {
      background: transparent;
      color: var(--gold);
      border: 1.5px solid var(--gold);
      box-shadow: inset 0 -2px 12px rgba(166, 124, 0, 0.15), 0 0 12px rgba(166, 124, 0, 0.08);
    }

    .btn-primary:hover {
      color: var(--gold-light);
      border-color: var(--gold-light);
      box-shadow: inset 0 -8px 24px rgba(166, 124, 0, 0.3), 0 0 24px rgba(166, 124, 0, 0.2);
    }

    .btn-secondary {
      background: transparent;
      color: var(--text-secondary);
      border: 2px solid #4a4a55;
    }

    .btn-secondary:hover {
      color: var(--text-primary);
      border-color: #70707d;
      box-shadow: inset 0 -6px 20px rgba(255, 255, 255, 0.08), 0 0 16px rgba(255, 255, 255, 0.05);
    }
    
    .btn-sm {
      padding: 8px 16px;
      font-size: 14px;
    }
    
    /* ========== Hero ========== */
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      padding-top: 64px;
      /* Hero: Gold glow on the heading area + silver diagonal ambient light */
      background:
        radial-gradient(ellipse 60% 40% at 50% 35%, rgba(166, 124, 0, 0.20) 0%, transparent 60%),
        linear-gradient(135deg, rgba(255, 255, 255, 0.03) 0%, transparent 50%, rgba(255, 255, 255, 0.02) 100%),
        linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-elevated) 100%);
    }
    
    .hero-content {
      text-align: center;
      max-width: 800px;
      margin: 0 auto;
    }
    
    .hero-icon {
      width: 80px;
      height: 80px;
      margin-bottom: var(--space-md);
    }
    
    .hero h1 {
      font-size: clamp(40px, 8vw, 64px);
      font-weight: 700;
      line-height: 1.1;
      margin-bottom: var(--space-md);
    }
    
    .hero h1 .gold {
      color: var(--gold);
    }
    
    .hero .subtitle {
      font-size: clamp(18px, 3vw, 24px);
      color: var(--text-secondary);
      margin-bottom: var(--space-lg);
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }
    
    .hero-buttons {
      display: flex;
      gap: var(--space-sm);
      justify-content: center;
      flex-wrap: wrap;
    }
    
    .hero-scroll {
      margin-top: var(--space-xl);
      font-size: 15px;
    }

    .hero-scroll a {
      color: var(--text-secondary);
      transition: color 0.2s;
    }

    .hero-scroll a:hover {
      color: var(--gold-light);
    }
    
    /* ========== Sections ========== */
    .section-header {
      text-align: center;
      margin-bottom: var(--space-xl);
    }
    
    .section-header h2 {
      font-size: clamp(28px, 5vw, 40px);
      font-weight: 700;
      margin-bottom: var(--space-sm);
    }
    
    .section-header p {
      color: var(--text-secondary);
      font-size: 18px;
      max-width: 600px;
      margin: 0 auto;
    }
    
    /* ========== Bridge Section ========== */
    .bridge {
      /* Bridge: Silver diagonal — large area ambient light */
      background: linear-gradient(135deg, #141416 0%, #1a1a1f 40%, #1d1d22 60%, #141416 100%);
    }
    
    .bridge-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--space-md);
    }
    
    .bridge-card {
      padding: var(--space-md);
      background: linear-gradient(135deg, #131315 0%, #18181c 100%);
      border-radius: var(--radius-lg);
      border: 1px solid #363640;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    }

    .bridge-card:hover {
      border-color: rgba(200, 200, 220, 0.35);
      box-shadow: 0 6px 24px rgba(0, 0, 0, 0.5), 0 0 20px rgba(200, 200, 220, 0.06);
      transform: translateY(-1px);
    }
    
    .bridge-card h3 {
      font-size: 18px;
      margin-bottom: var(--space-xs);
      display: flex;
      align-items: center;
      gap: var(--space-xs);
    }
    
    .bridge-card p {
      color: var(--text-secondary);
      font-size: 15px;
    }
    
    /* ========== Features ========== */
    /* Features: Silver diagonal only (alternates — hero=gold, bridge=silver, features=silver, security=gold) */
    #features {
      background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.025) 0%, transparent 40%, rgba(255, 255, 255, 0.02) 100%),
        var(--bg-primary);
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: var(--space-md);
    }
    
    .feature-card {
      padding: var(--space-lg);
      background: linear-gradient(135deg, #151517 0%, #1a1a1f 100%);
      border-radius: var(--radius-lg);
      border: 1px solid #363640;
      box-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
      text-align: center;
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    }

    .feature-card:hover {
      border-color: rgba(166, 124, 0, 0.6);
      box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5), 0 0 24px rgba(166, 124, 0, 0.12);
      transform: translateY(-2px);
    }
    
    .feature-icon {
      font-size: 40px;
      margin-bottom: var(--space-sm);
    }
    
    .feature-card h3 {
      font-size: 20px;
      margin-bottom: var(--space-xs);
    }
    
    .feature-card p {
      color: var(--text-secondary);
      font-size: 15px;
    }
    
    /* ========== Security Section ========== */
    .security {
      /* Security: Gold glow + silver diagonal (alternates with Features' silver-only) */
      background:
        radial-gradient(ellipse 70% 50% at 50% 40%, rgba(166, 124, 0, 0.10) 0%, transparent 60%),
        linear-gradient(135deg, #141416 0%, #1c1c22 35%, #1f1f25 50%, #1c1c22 65%, #141416 100%);
    }
    
    .security-list {
      max-width: 700px;
      margin: 0 auto;
    }
    
    .security-item {
      display: flex;
      gap: var(--space-sm);
      padding: var(--space-sm) 0;
      border-bottom: 1px solid var(--border);
    }
    
    .security-item:last-child {
      border-bottom: none;
    }
    
    .security-check {
      color: var(--gold);
      font-size: 20px;
      flex-shrink: 0;
    }
    
    .security-item p {
      font-size: 16px;
    }
    
    .security-item strong {
      color: var(--text-primary);
    }
    
    .security-item span {
      color: var(--text-secondary);
      font-size: 15px;
    }
    
    /* ========== Compatibility ========== */
    .compat-wallets {
      display: flex;
      justify-content: center;
      gap: var(--space-lg);
      flex-wrap: wrap;
      margin-bottom: var(--space-lg);
    }
    
    .wallet-badge {
      padding: var(--space-sm) var(--space-md);
      background: linear-gradient(135deg, #151517 0%, #1a1a1f 100%);
      border: 1px solid #2a2a30;
      border-radius: var(--radius-md);
      font-size: 16px;
      color: var(--text-primary);
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    }
    
    .compat-note {
      text-align: center;
      color: var(--text-secondary);
      font-size: 16px;
      max-width: 600px;
      margin: 0 auto;
    }
    
    .compat-note strong {
      color: var(--gold);
    }
    
    /* ========== Download Section ========== */
    .download {
      text-align: center;
      /* Download: Gold pooling under the CTA buttons — "click me" warmth */
      background:
        radial-gradient(ellipse 50% 35% at 50% 60%, rgba(166, 124, 0, 0.18) 0%, transparent 60%),
        linear-gradient(135deg, rgba(255, 255, 255, 0.02) 0%, transparent 50%),
        var(--bg-primary);
    }
    
    .download-buttons {
      display: flex;
      gap: var(--space-md);
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: var(--space-md);
    }
    
    .download-info {
      color: var(--text-muted);
      font-size: 14px;
    }
    
    /* ========== About/Footer ========== */
    .about {
      /* About: Silver diagonal fading to black — gentle exit */
      background: linear-gradient(135deg, #1a1a1f 0%, #161618 50%, var(--bg-primary) 100%);
    }
    
    .about-content {
      max-width: 600px;
      margin: 0 auto;
      text-align: center;
    }
    
    .about-content p {
      color: var(--text-secondary);
      margin-bottom: var(--space-md);
    }
    
    .contact-email {
      font-size: 18px;
      color: var(--gold);
    }
    
    footer {
      padding: var(--space-md) 0;
      text-align: center;
      color: var(--text-muted);
      font-size: 14px;
    }
    
    footer a {
      color: var(--text-muted);
      margin: 0 var(--space-sm);
    }
    
    footer a:hover {
      color: var(--gold);
    }
    
    /* ========== Responsive ========== */
    @media (max-width: 768px) {
      nav {
        display: none;
      }
      
      .hero h1 {
        font-size: 36px;
      }
      
      section {
        padding: var(--space-xl) 0;
      }
    }
  </style>
</head>

<body>
  <!-- Header -->
  <header>
    <div class="container header-inner">
      <a href="/" class="logo">
        <img src="/Hodos_Gold_Browser_Icon.svg" alt="Hodos Browser" />
      </a>
      <nav>
        <a href="#features">Features</a>
        <a href="#security">Security</a>
        <a href="#download">Download</a>
        <a href="#about">About</a>
      </nav>
    </div>
  </header>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-content">
        <img src="/Hodos_Gold_Icon.svg" alt="Hodos Browser" class="hero-icon" />
        <h1>Browse the web.<br><span class="gold">Own your wallet.</span></h1>
        <p class="subtitle">The browser with a built-in BitcoinSV wallet. No extensions. No friction. Just familiar browsing with native BSV.</p>
        <div class="hero-buttons">
          <a href="https://github.com/Hodos-Browser/Hodos-Browser/releases/download/v0.2.0-beta.1/HodosBrowser-0.2.0-beta.1-setup.exe" class="btn btn-primary">Download for Windows</a>
          <a href="https://github.com/Hodos-Browser/Hodos-Browser/releases/download/v0.2.0-beta.1/HodosBrowser-0.2.0-beta.1.dmg" class="btn btn-secondary">Download for Mac</a>
        </div>
        <p class="hero-scroll"><a href="#bridge">↓ Learn more</a></p>
      </div>
    </div>
  </section>

  <!-- Bridge Section -->
  <section class="bridge" id="bridge">
    <div class="container">
      <div class="section-header">
        <h2>Your bridge to Web3</h2>
        <p>The internet you know, with the future built in.</p>
      </div>
      <div class="bridge-grid">
        <div class="bridge-card">
          <h3>🌐 Full Web Compatibility</h3>
          <p>Browse any website. Everything works exactly as you'd expect. No compromises.</p>
        </div>
        <div class="bridge-card">
          <h3>💸 Native BSV Payments</h3>
          <p>When sites support BitcoinSV, pay seamlessly. No extensions to install or manage.</p>
        </div>
        <div class="bridge-card">
          <h3>🔄 Use Your Existing Wallet</h3>
          <p>Recover from HandCash, RockWallet, Centbee, or start fresh. Your choice.</p>
        </div>
        <div class="bridge-card">
          <h3>🚀 BRC-100 Ready</h3>
          <p>Built on the latest wallet standard. Future-proof from day one.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features">
    <div class="container">
      <div class="section-header">
        <h2>Built different</h2>
        <p>Not another Electron wrapper. A real browser with a real wallet.</p>
      </div>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">💰</div>
          <h3>Native Wallet</h3>
          <p>BitcoinSV built into the browser. Not bolted on. Your keys never leave your device.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🛡️</div>
          <h3>Private by Design</h3>
          <p>Like Brave and Firefox, we respect your privacy. No tracking, no data collection.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🚫</div>
          <h3>Ad-Free Browsing</h3>
          <p>Built-in ad and tracker blocking. Faster pages, cleaner experience.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3>Native Performance</h3>
          <p>Built on Chromium. Fast, efficient, and familiar.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Security -->
  <section class="security" id="security">
    <div class="container">
      <div class="section-header">
        <h2>Security you can trust</h2>
        <p>We handle real money. We take that seriously.</p>
      </div>
      <div class="security-list">
        <div class="security-item">
          <span class="security-check">✓</span>
          <p><strong>Wallet runs in isolated process</strong> <span>— Your keys never touch JavaScript or web content.</span></p>
        </div>
        <div class="security-item">
          <span class="security-check">✓</span>
          <p><strong>Written in Rust</strong> <span>— The language trusted by Mozilla, Microsoft, and Cloudflare for security-critical code.</span></p>
        </div>
        <div class="security-item">
          <span class="security-check">✓</span>
          <p><strong>Process-per-tab isolation</strong> <span>— Same security model as Brave and Firefox.</span></p>
        </div>
        <div class="security-item">
          <span class="security-check">✓</span>
          <p><strong>Per-site spending limits</strong> <span>— You control how much each site can request.</span></p>
        </div>
        <div class="security-item">
          <span class="security-check">✓</span>
          <p><strong>Encrypted locally</strong> <span>— Your wallet is protected with your PIN and OS-level encryption.</span></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Wallet Compatibility -->
  <section id="compatibility">
    <div class="container">
      <div class="section-header">
        <h2>Works with wallets you know</h2>
        <p>Recover your existing wallet or start fresh.</p>
      </div>
      <div class="compat-wallets">
        <span class="wallet-badge">HandCash</span>
        <span class="wallet-badge">RockWallet</span>
        <span class="wallet-badge">Centbee</span>
        <span class="wallet-badge">Any BIP-39 wallet</span>
      </div>
      <p class="compat-note">
        Plus full <strong>BRC-100</strong> compatibility — the new standard for BitcoinSV app authentication and payments.
      </p>
    </div>
  </section>

  <!-- Download -->
  <section class="download" id="download">
    <div class="container">
      <div class="section-header">
        <h2>Ready to try it?</h2>
        <p>Download Hodos Browser and see for yourself.</p>
      </div>
      <div class="download-buttons">
        <a href="https://github.com/Hodos-Browser/Hodos-Browser/releases/download/v0.2.0-beta.1/HodosBrowser-0.2.0-beta.1-setup.exe" class="btn btn-primary">⬇ Download for Windows</a>
        <a href="https://github.com/Hodos-Browser/Hodos-Browser/releases/download/v0.2.0-beta.1/HodosBrowser-0.2.0-beta.1.dmg" class="btn btn-secondary">⬇ Download for macOS</a>
      </div>
      <p class="download-info">
        Version 0.2.0-beta.1 • Windows 10+ • macOS 10.15+
      </p>
    </div>
  </section>

  <!-- About -->
  <section class="about" id="about">
    <div class="container">
      <div class="about-content">
        <h2>Built by Marston Enterprises</h2>
        <p>
          We believe the internet should work for you — not advertisers, not data brokers, not middlemen. 
          Hodos Browser is our step toward that future.
        </p>
        <p>
          Questions? Feedback? We'd love to hear from you.
        </p>
        <a href="mailto:contact@hodosbrowser.com" class="contact-email">contact@hodosbrowser.com</a>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer>
    <div class="container">
      <p>
        © 2026 Marston Enterprises
        <a href="#">Privacy</a>
        <a href="#">Terms</a>
        <a href="#">GitHub</a>
      </p>
    </div>
  </footer>

</body>
</html>
